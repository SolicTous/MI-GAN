```gitignore
# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Build and distribution
dist/
build/
*.egg-info/

# Dependencies
venv/
.venv/
.env
.env.local
.env.*

# Logs
*.log

# Coverage reports
.coverage
htmlcov/
coverage/

# IDE specific
.vscode/
.idea/
*.swp
*.swo
*.tmp

# OS specific
.DS_Store
Thumbs.db
```